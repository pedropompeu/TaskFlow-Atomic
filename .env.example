# ─── Database ────────────────────────────────────────────────
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow_pass
POSTGRES_DB=taskflow_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass

# ─── JWT ─────────────────────────────────────────────────────
# IMPORTANT: change these secrets in production (use openssl rand -base64 64)
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── Backend ─────────────────────────────────────────────────
BACKEND_PORT=3001
NODE_ENV=development

# ─── Frontend ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Email (Mailtrap — SMTP mock for development) ────────────
# Get credentials at: https://mailtrap.io
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=your_mailtrap_user
MAIL_PASS=your_mailtrap_password
MAIL_FROM=noreply@taskflow.dev

# ─── File Upload ─────────────────────────────────────────────
UPLOAD_DEST=./uploads
MAX_FILE_SIZE=10485760
